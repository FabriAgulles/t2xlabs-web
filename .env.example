# =============================================================================
# VARIABLES DE ENTORNO - t2xLabs Web Application
# =============================================================================

# ⚠️  IMPORTANTE: NO INCLUIR VALORES REALES EN ESTE ARCHIVO
# Este archivo es una plantilla. Copiar a .env y completar con valores reales.

# =============================================================================
# VARIABLES PÚBLICAS (Incluidas en el bundle del cliente)
# =============================================================================
# IMPORTANTE: Cualquier variable con prefijo VITE_ será incluida en el
# bundle JavaScript y será visible públicamente en el navegador.
# NO usar VITE_ para datos sensibles.

# Google Analytics (Opcional - El GA ID puede ser público)
# VITE_PUBLIC_GA_ID=G-XXXXXXXXXX

# =============================================================================
# VARIABLES PRIVADAS (SOLO accesibles en Netlify Functions / Backend)
# =============================================================================
# Estas variables NO deben tener el prefijo VITE_
# Solo son accesibles desde process.env en Netlify Functions

# Airtable API Credentials
# Obtener desde: https://airtable.com/account
# Base ID: Se encuentra en la URL de tu base (https://airtable.com/appXXXXXXXXXXXXXX)
# Token: Crear un Personal Access Token en tu cuenta de Airtable
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TOKEN=patXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Cloudflare Turnstile (Opcional - Anti-bot CAPTCHA)
# Obtener desde: https://dash.cloudflare.com/
# Si no se implementa CAPTCHA, dejar comentadas estas líneas
# TURNSTILE_SITE_KEY=0x4XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# TURNSTILE_SECRET_KEY=0x4XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# CONFIGURACIÓN DE DESARROLLO (Opcional)
# =============================================================================
# NODE_ENV=development
# VITE_DEV_MODE=true

# =============================================================================
# INSTRUCCIONES DE USO
# =============================================================================

# 1. DESARROLLO LOCAL:
#    - Copiar este archivo a .env
#    - Reemplazar los valores XXX con credenciales reales
#    - NUNCA commitear el archivo .env al repositorio

# 2. NETLIFY (PRODUCCIÓN):
#    - Ir a: Netlify Dashboard → Site settings → Environment variables
#    - Añadir cada variable (sin prefijo VITE_ para secretos)
#    - Scope: "All deploys" o según necesidad

# 3. SEGURIDAD:
#    - NUNCA usar prefijo VITE_ para API tokens, passwords, o secrets
#    - VITE_ solo para configuración pública que puede ser visible
#    - Las variables sin VITE_ solo son accesibles en Netlify Functions

# =============================================================================
# ROTACIÓN DE CREDENCIALES
# =============================================================================
# Si las credenciales actuales fueron expuestas:
# 1. Generar nuevas credenciales en Airtable
# 2. Actualizar en .env local
# 3. Actualizar en Netlify Dashboard
# 4. Revocar las credenciales antiguas
# 5. Desplegar cambios (las functions usarán las nuevas credenciales)
